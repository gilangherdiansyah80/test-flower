{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.1"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|fonts)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "MovieBook",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:g1CFrXMTT+860j/nG4fY7PAs6knhOHgCurtzLydxDlM=",
        "APP_URL": "",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "sqlite",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "array",
        "QUEUE_CONNECTION": "sync",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "OMDB_API_KEY": "699b04d5",
        "VERCEL": "1"
    }
}
